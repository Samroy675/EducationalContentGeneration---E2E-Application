@inherits LayoutComponentBase

    <aside class="sidebar">
        <div class="sidebar-header">
            <h3>EducationalContentGeneration</h3>
            <small>AI Command Center</small>
        </div>

        <nav class="nav-menu">
            <NavLink href="/mcq" class="nav-item" ActiveClass="active" Match="NavLinkMatch.Prefix">
                <i class="bi bi-list-check nav-icon" aria-hidden="true"></i>
                <span>MCQ Generator</span>
            </NavLink>

            <NavLink href="/short-answer" class="nav-item" ActiveClass="active">
                <i class="bi bi-pencil-square nav-icon" aria-hidden="true"></i>
                <span>Short Answer</span>
            </NavLink>

            <NavLink href="/long-answer" class="nav-item" ActiveClass="active">
                <i class="bi bi-journal-text nav-icon" aria-hidden="true"></i>
                <span>Long Answer</span>
            </NavLink>

            <NavLink href="/explanation" class="nav-item" ActiveClass="active">
                <i class="bi bi-lightbulb nav-icon" aria-hidden="true"></i>
                <span>Answer Explainer</span>
            </NavLink>

            <NavLink href="/question-paper" class="nav-item" ActiveClass="active">
                <i class="bi bi-file-earmark-text nav-icon" aria-hidden="true"></i>
                <span>Question Paper Builder</span>
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            <NavLink href="/history" class="nav-item history" ActiveClass="active">
                <i class="bi bi-clock-history nav-icon" aria-hidden="true"></i>
                <span>History</span>
            </NavLink>
        </div>
    </aside>
