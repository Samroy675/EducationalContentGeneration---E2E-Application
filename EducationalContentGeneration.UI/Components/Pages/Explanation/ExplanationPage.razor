@page "/explanation"
@using EducationalContentGeneration.Core.Enums
@using EducationalContentGeneration.Core.Models
@using EducationalContentGeneration.UI.Components.Services
@inject MockDataService MockService

<PageTitle>Explanation Generator</PageTitle>

<h3>Explanation Generator</h3>

<div class="page-layout">
    <div class="form-container">
        <EditForm Model="@request" OnSubmit="@GenerateExplanation" FormName="explanationForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label>Subject:</label>
                <InputText @bind-Value="request.Subject" class="form-control" />
            </div>

            <div class="form-group">
                <label>Topic:</label>
                <InputText @bind-Value="request.Topic" class="form-control" />
            </div>

            <div class="form-group">
                <label>Class Level:</label>

                <InputSelect @bind-Value="request.ClassLevel" class="form-control">
                    <option value="">--Select Class</option>
                    @foreach (EducationClass level in Enum.GetValues(typeof(EducationClass)))
                    {
                        <option value="@level">@level</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group">
                <label>Difficulty:</label>

                <InputSelect @bind-Value="request.Difficulty" class="form-control">
                    <option value="">--Select Difficulty</option>
                    @foreach (DifficultyLevel level in Enum.GetValues(typeof(DifficultyLevel)))
                    {
                        <option value="@level">@level</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group">
                <label>Question:</label>
                <InputTextArea @bind-Value="request.Questions[0].Question" class="form-control" rows="3" />
            </div>

            <div class="form-group">
                <label>Answer:</label>
                <InputTextArea @bind-Value="request.Questions[0].Answer" class="form-control" rows="3" />
            </div>

            <br />

            <button type="submit" class="btn btn-primary" disabled="@isLoading">
                @(isLoading ? "Generating..." : "Generate")
            </button>
        </EditForm>
    </div>

    @if (isLoading)
    {
        <p>Generating detailed explanation... </p>
    }

    @if (!string.IsNullOrWhiteSpace(result))
    {
        <div class="result-box">
            <pre>@result</pre>
        </div>
    }
</div>

@code {
    private ExplanationRequest request = new()
    {
        Questions = new List<QuestionAnswerPair>
        {
            new QuestionAnswerPair()
        }
    };
    private string? result;
    private bool isLoading = false;
    

    private async Task GenerateExplanation()
    {
        isLoading = true;
        result = null;

        await Task.Delay(1000);

        result = MockService.GenerateExplanation(request);

        isLoading = false;
    }

}