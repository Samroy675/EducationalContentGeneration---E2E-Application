@page "/question-paper"
@using EducationalContentGeneration.Core.Models
@using EducationalContentGeneration.UI.Services
@using System.Text.Json
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject ContentApiService ContentService

<TopBar Title="Question Paper Builder" BadgeText="Builder" BadgeClass="tag-purple"
        ShowExportKey="true" ContentToCopy="@BuildQuestionPaperText()" />

<div class="two-panel">
    <div class="form-panel">
        <!-- Exam / Revision mode toggle — belongs here in QP -->
        <div class="mode-toggle" @onclick="() => _examMode = !_examMode">
            <span class="mode-label @(_examMode ? "active" : "")">Exam Mode</span>
            <div class="switch @(_examMode ? "" : "on")"></div>
            <span class="mode-label @(!_examMode ? "active" : "")">Revision Mode</span>
        </div>
        <div class="mode-hint">
            @(_examMode ? "📝 Answers hidden — suitable for printing exam papers" : "📖 Answers visible — suitable for revision and study")
        </div>

        <div class="form-group">
            <label class="form-label">Subject</label>
            <input class="form-control" @bind="_request.subject" placeholder="e.g. Science" />
        </div>
        <div class="form-group">
            <label class="form-label">Grade Level</label>
            <select class="form-control" @bind="_request.classLevel">
                @foreach (var g in Enum.GetValues<Core.Enums.EducationClass>()) { <option value="@g">@g</option> } </select>
        </div>
        <div class="form-group">
            <label class="form-label">Difficulty</label>
            <div class="toggle-group">
                @foreach (var d in Enum.GetValues<Core.Enums.DifficultyLevel>()) {
                    <button class="toggle-btn @(_request.difficultyLevel == d ? "active" : "")"
                            @onclick="() => _request.difficultyLevel = d"> @d </button> }
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">MCQ Count</label>
            <div class="count-control">
                <button class="count-btn" @onclick="() => _request.mcqCount = (byte)Math.Max(0, (_request.mcqCount ?? 1) - 1)">−</button>
                <span class="count-val">@_request.mcqCount</span>
                <button class="count-btn" @onclick="() => _request.mcqCount++">+</button>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Short Answer Count</label>
            <div class="count-control">
                <button class="count-btn" @onclick="() => _request.shortAnswerCount = (byte)Math.Max(0, (_request.shortAnswerCount ?? 1) - 1)">−</button>
                <span class="count-val">@_request.shortAnswerCount</span>
                <button class="count-btn" @onclick="() => _request.shortAnswerCount++">+</button>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Long Answer Count</label>
            <div class="count-control">
                <button class="count-btn" @onclick="() => _request.longAnswerCount = (byte)Math.Max(0, (_request.longAnswerCount ?? 1) - 1)">−</button>
                <span class="count-val">@_request.longAnswerCount</span>
                <button class="count-btn" @onclick="() => _request.longAnswerCount++">+</button>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Exam Duration</label>
            <select class="form-control" @bind="_request.examDuration">
                <option value="30">30 min</option><option value="45">45 min</option>
                <option value="60">60 min</option><optionvalue="90">90 min</optionvalue>
                <option value="120">120 min</option value="180"><option>180 min</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Total Marks</label>
            <input class="form-control" type="number" @bind="_request.totalMarks" min="10" step="5" />
        </div>

        <div class="marks-summary">
            <div class="marks-row"><span>MCQ (@_request.mcqCount × 1)</span><span class="marks-val">@_request.mcqCount</span></div>
            <div class="marks-row"><span>Short Ans. (@_request.shortAnswerCount × 2)</span><span class="marks-val">@(_request.shortAnswerCount * 2)</span></div>
            <div class="marks-row"><span>Long Ans. (@_request.longAnswerCount × 5)</span><span class="marks-val">@(_request.longAnswerCount * 5)</span></div>
            <div class="marks-row marks-total">
                <span>Calculated Total</span>
                <span class="marks-val">@(_request.mcqCount + _request.shortAnswerCount * 2 + _request.longAnswerCount * 5)</span>
            </div>
        </div>

        <button class="generate-btn" @onclick="GenerateAsync" disabled="@_isLoading">
            @(_isLoading ? "⏳ Building..." : "⚡ Build Question Paper")
        </button>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="error-msg">⚠ @_error</div>
        }
    </div>

    <div class="preview-panel">
        @if (_isLoading)
        {
            <div style="display:flex;flex-direction:column;gap:12px;align-items:center;justify-content:center;height:300px">
                <div style="font-size:18px;margin-bottom:10px;">🤖 AI is generating your question paper...</div>
                @for (int i = 0; i < 4; i++) { <div class="skeleton" style="height:80px;border-radius:12px;width:80%"></div> }
            </div>
        } 
        else if (_result is null)
        {
            <div class="empty-state">
                <div class="empty-icon">📄</div>
                <div class="empty-title">Question Paper Builder</div>
                <div class="empty-sub">Configure counts, marks and duration to generate a complete exam paper</div>
            </div>
        }
        else
        {
            <div class="qp-paper-header">
                <div class="qp-paper-title">MODEL QUESTION PAPER</div>
                <div class="qp-paper-meta">@_request.subject · @_request.classLevel · @_request.difficultyLevel</div>
                <div class="qp-paper-info">
                    <span>⏱ @_result.ExamInfo.ExamDuration</span>
                    <span>📝 Total Marks: @_result.ExamInfo.TotalMarks</span>
                    <span class="tag @(_examMode ? "tag-amber" : "tag-blue")" style="font-size:10px">
                        @(_examMode ? "EXAM MODE" : "REVISION MODE")
                    </span>
                </div>
            </div>

            @if (_result?.Sections?.Mcq?.Any() == true)
            {
                <div class="qp-section-header">
                    <span class="tag tag-green">MCQ</span>
                    Section A — Multiple Choice
                    <span class="qp-marks-note">@_result.Sections.Mcq.Count × 1 = @_result.Sections.Mcq.Count marks</span>
                </div>
                @for (int i = 0; i < _result.Sections.Mcq.Count; i++)
                {
                    <McqCard Question="@_result.Sections.Mcq[i]" Number="@(i+1)" RevisionMode="@(!_examMode)" />
                } 
            }

            @if (_result?.Sections?.ShortAnswers?.Any() == true)
            {
                var offset = _result.Sections.Mcq.Count;
                <div class="qp-section-header">
                    <span class="tag tag-blue">SA</span>
                    Section B — Short Answer
                    <span class="qp-marks-note">@_result.Sections.ShortAnswers.Count × 2 = @(_result.Sections.ShortAnswers.Count * 2) marks</span>
                </div>
                @for (int i = 0; i < _result.Sections.ShortAnswers.Count; i++)
                {
                    var q = _result.Sections.ShortAnswers[i]; var num = offset + i + 1;
                    <div class="sa-card">
                        <div class="q-num-inline">Q@(num)</div>
                        <div class="sa-q">@q.Question</div>
                        @if (!_examMode)
                        {
                            <div class="sa-answer-box">@q.Answer</div>
                            @if (q.KeyPoints.Any())
                            {
                                <div class="sa-keypoints" style="margin-top:8px">
                                    @foreach (var pt in q.KeyPoints) { <span class="keypoint">@pt</span> }
                                </div>
                            }
                        }
                        else
                        {
                            <div style="font-size:11.5px;color:var(--text3);font-family:'DM Mono',monospace;margin-top:4px">[2 marks · 3-5 lines]</div>
                        }
                    </div>
                }
            }

            @if (_result?.Sections?.LongAnswers?.Any() == true)
            {
                var laOffset = _result.Sections.Mcq.Count + _result.Sections.ShortAnswers.Count;
                <div class="qp-section-header">
                    <span class="tag tag-purple">LA</span>
                    Section C — Long Answer
                    <span class="qp-marks-note">@_result.Sections.LongAnswers.Count × 5 = @(_result.Sections.LongAnswers.Count*5) marks</span>
                </div>
                @for (int i = 0; i < _result.Sections.LongAnswers.Count; i++)
                {
                    var q = _result.Sections.LongAnswers[i]; var num = laOffset + i + 1;
                    <div class="sa-card">
                        <div class="q-num-inline">Q@(num)</div>
                        <div class="sa-q">@q.Question</div>
                        @if (!_examMode)
                        {
                            <div class="la-section-label">Answer</div>
                            <div class="sa-answer-box" style="white-space:pre-line">@q.Answer</div>
                        }
                        else
                        {
                            <div style="font-size:11.5px;color:var(--text3);font-family:'DM Mono',monospace;margin-top:4px">[5 marks · 8-10 lines]</div>
                        }
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    private ContentGenerationRequest _request = new() { ContentType = Core.Enums.ContentGenerationType.QuestionPaper, difficultyLevel = Core.Enums.DifficultyLevel.Medium, classLevel = Core.Enums.EducationClass.Class6, mcqCount = 5, shortAnswerCount = 3, longAnswerCount = 2, examDuration = 60, totalMarks = 40 };
    private QuestionPaperResponse? _result;
    private bool _isLoading = false;
    private bool _examMode = true;
    private string _error = string.Empty;
    private readonly string[] _grades = ["Class 6","Class 7","Class 8","Class 9","Class 10"];

    private async Task GenerateAsync()
    {
        _error = string.Empty;
        if (string.IsNullOrWhiteSpace(_request.subject)) 
        { 
            _error = "Please enter a subject.";
            return; 
        }
        _isLoading = true; 
        StateHasChanged();

        _result = await ContentService.GenerateQuestionPaperAsync(_request);

        var historyItem = new HistoryItem
        {
            Type = "📋 Question Paper",
            Title = $"{_request.subject}",
            Content = $"MCQs: {_request.mcqCount}\nShort Answers: {_request.shortAnswerCount}\nLong Answers: {_request.longAnswerCount}\nTotal Marks: {_request.totalMarks}",
            Time = DateTime.Now
        };

        var json = JsonSerializer.Serialize(historyItem);
        await JS.InvokeVoidAsync("edugen.addHistoryItem", json);

        _isLoading = false;
    }

    private string BuildQuestionPaperText()
    {
        if (_result == null) return string.Empty;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"Subject: {_request.subject}");
        sb.AppendLine($"Class: {_request.classLevel}");
        sb.AppendLine($"Total Marks: {_request.totalMarks}");
        sb.AppendLine($"Duration: {_request.examDuration} mins");
        sb.AppendLine();
        int i = 1;
        foreach (var q in _result.Sections.Mcq)
        {
            sb.AppendLine($"Q{i++}. {q.question}");
            sb.AppendLine($"A. {q.options[0]}");
            sb.AppendLine($"B. {q.options[1]}");
            sb.AppendLine($"C. {q.options[2]}");
            sb.AppendLine($"D. {q.options[3]}");
            sb.AppendLine($"A{i++}. {q.correctAnswer}");
            sb.AppendLine();
    }

    foreach (var q in _result.Sections.ShortAnswers)
    {
        sb.AppendLine($"Q{i++}. {q.Question}");
        sb.AppendLine($"A{i++}. {q.Answer}");
        sb.AppendLine();
    }

    foreach (var q in _result.Sections.LongAnswers)
    {
        sb.AppendLine($"Q{i++}. {q.Question}");
        sb.AppendLine($"A{i++}. {q.Answer}");
        sb.AppendLine();
    }
    return sb.ToString();
  }
}
