@page "/short-answer"
@rendermode InteractiveServer
@using EducationalContentGeneration.Core.Models
@using EducationalContentGeneration.Core.Enums
@using EducationalContentGeneration.UI.Services
@using System.Text.Json
@inject IJSRuntime Js
@inject ContentApiService ContentService

<TopBar Title="Short Answer Generator" BadgeText="SA" BadgeClass="tag-blue"
        ShowExportKey="true" ContentToCopy="@GetCopyContent()" />

<div class="stats-bar">
    <div class="stat-item">Questions: <span class="stat-val">@_request.numberOfQuestions</span></div>
    <div class="stat-item">Subject: <span class="stat-val">@(_request.subject.OrDash())</span></div>
    <div class="stat-item">Grade: <span class="stat-val">@(_request.classLevel)</span></div>
    <div class="stat-item">Difficulty: <span class="stat-val">@_request.difficultyLevel</span></div>
    @if (_questions.Count > 0)
    {
        <div class="stat-item" style="margin-left:auto">
            <span class="tag tag-green">@_questions.Count Generated</span>
        </div>
    }
</div>

<div class="two-panel">
    <div class="form-panel">
        <div class="form-group">
            <label class="form-label">subject</label>
            <input class="form-control" @bind="_request.subject" placeholder="e.g. Biology" />
        </div>
        <div class="form-group">
            <label class="form-label">Topic</label>
            <input class="form-control" @bind="_request.topic" placeholder="e.g. Photosynthesis" />
        </div>
        <div class="form-group">
            <label class="form-label">Grade Level</label>
            <select class="form-control" @bind="_request.classLevel">
                @foreach (var g in _grades) { <option value="@g">@g</option> }
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Difficulty</label>
            <div class="toggle-group">
                @foreach (var d in Enum.GetValues<Core.Enums.DifficultyLevel>())
                {
                    <button class="toggle-btn @(_request.difficultyLevel == d ? "active" : "")"
                            @onclick="() => _request.difficultyLevel = d">@d</button>
                }
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">No. of Questions</label>
            <div class="count-control">
                <button class="count-btn" @onclick="() => _request.numberOfQuestions = (byte)Math.Max(1, (_request.numberOfQuestions ?? 1) - 1)">−</button>
                <span class="count-val">@_request.numberOfQuestions</span>
                <button class="count-btn" @onclick="() => _request.numberOfQuestions = (byte)Math.Min(30, (_request.numberOfQuestions ?? 1) + 1)">+</button>
            </div>
        </div>
        <button class="generate-btn" @onclick="GenerateAsync" disabled="@_isLoading">
            @(_isLoading ? "⏳ Generating..." : "⚡ Generate Short Answers")
        </button>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="error-msg">⚠ @_error</div>
        }
    </div>

    <div class="preview-panel">
        @if (_isLoading)
        {
            <div style="display:flex;flex-direction:column;gap:12px;align-items:center;justify-content:center;height:300px">
                <div style="font-size:18px;margin-bottom:10px;">🤖 AI is generating short answers...</div>
                @for (int i = 0; i < 4; i++)
                {
                    <div class="skeleton" style="height:80px;border-radius:12px;width:80%"></div>
                }
            </div>
        }
        else if (_questions.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">✏️</div>
                <div class="empty-title">Short Answer Mode</div>
                <div class="empty-sub">Each question includes a concise answer and key points</div>
            </div>
        }
        else
        {
            <div class="preview-header">
                <div class="preview-meta">
                    <span class="tag tag-green">@_request.subject</span>
                    <span class="tag tag-blue">@_request.classLevel</span>
                    <span class="tag tag-amber">@_request.difficultyLevel</span>
                </div>
            </div>
            @for (int i = 0; i < _questions.Count; i++)
            {
                var q = _questions[i]; var num = i + 1;
                <div class="sa-card">
                    <div class="q-num-inline">Q@(num)</div>
                    <div class="sa-q">@q.Question</div>
                    <div class="sa-answer-box">@q.Answer</div>
                    @if (q.KeyPoints.Any())
                    {
                        <div class="form-label" style="margin-top:10px;margin-bottom:5px">Key Points</div>
                        <div class="sa-keypoints">
                            @foreach (var pt in q.KeyPoints) { <span class="keypoint">@pt</span> }
                        </div>
                    }
                    <div class="q-actions">
                        <button class="q-action-btn" @onclick="() => CopyQuestion(q, num)">📋 Copy</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private ContentGenerationRequest _request = new() { ContentType = Core.Enums.ContentGenerationType.ShortAnswer, numberOfQuestions = 5, difficultyLevel = Core.Enums.DifficultyLevel.Medium, classLevel = Core.Enums.EducationClass.Class6 };
    private List<Core.Models.ShortAnswerQuestion> _questions = new();
    private bool _isLoading = false;
    private string _error = string.Empty;
    private readonly string[] _grades = ["Class6","Class7","Class8","Class9","Class10"];
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private async Task GenerateAsync()
    {
        _error = string.Empty;
        if (string.IsNullOrWhiteSpace(_request.subject))
        {
            _error = "Please enter a subject.";
            return;
        }
        _isLoading = true;

        _questions.Clear();
        StateHasChanged();

        try
        {
            _questions = await ContentService.GenerateShortAnswerAsync(_request);
            _error = "";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        var historyItem = new HistoryItem
        {
            Type = "✏️ Short Answer",
            Title = $"{_request.subject} - {_request.topic}",
            Content = string.Join("\n\n", _questions.Select((q, i) => 
            $"Q{i+1}. {q.Question}\n\nAnswer: {q.Answer}")),
            Time = DateTime.Now
        };

        var json = JsonSerializer.Serialize(historyItem);
        await JS.InvokeVoidAsync("edugen.addHistoryItem", json);

        _isLoading = false;
    }

    private string GetCopyContent()
    {
        if (_questions == null || !_questions.Any()) return string.Empty;

        return string.Join("\n\n", _questions.Select((q, i) =>
        $"Q{i + 1}.{q.Question}\nAnswer:{q.Answer}"));
    }

    private async Task CopyQuestion(Core.Models.ShortAnswerQuestion q, int num)
    {
        var text = $"Q{num}: {q.Question}\nAnswer: {q.Answer}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        await JS.InvokeVoidAsync("edugen.showToast", "Copied!");
    }
}
